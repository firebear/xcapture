{
  "name": "xcapture",
  "version": "1.0.0",
  "description": "Capture X.com tweets as images with original styling",
  "main": "index.js",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && npm run copy-files",
    "build:dev": "node scripts/bump-build.js && vite build && npm run copy-files",
    "bump:build": "node scripts/bump-build.js",
    "copy-files": "cp -r assets dist/",
    "clean": "rm -rf dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-copy": "^0.1.6"
  },
  "dependencies": {
    "html-to-image": "^1.11.13"
  }
}
