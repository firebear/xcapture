{
  "name": "xcapture",
  "version": "1.0.3",
  "description": "Capture X.com tweets as images with original styling",
  "main": "index.js",
  "scripts": {
    "dev": "npm run build && vite build --watch --emptyOutDir=false",
    "build": "vite build && npm run prepare:release && npm run validate:release",
    "build:dev": "node scripts/bump-build.js && vite build && npm run prepare:release && npm run validate:release",
    "bump:build": "node scripts/bump-build.js",
    "prepare:release": "node scripts/prepare-release.js",
    "validate:release": "node scripts/validate-release.js",
    "package:store": "npm run build && node scripts/package-store.js",
    "test:release": "npm run build && node --test tests/release-manifest.test.js",
    "clean": "rm -rf dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-copy": "^0.1.6"
  },
  "dependencies": {
    "html-to-image": "^1.11.13"
  }
}
